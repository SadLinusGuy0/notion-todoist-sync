# -----------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY
# On Railway, set these in the Variables dashboard — do NOT deploy a .env
# file. The .env file is listed in .gitignore and must never be committed.
# -----------------------------------------------------------------------

# Todoist API token — get from https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_api_token_here

# Notion integration secret — get from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_notion_api_key_here

# The ID of the Notion database to sync with.
# Find it in the database page URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# A random secret used to validate HMAC-SHA256 signatures on inbound Todoist webhooks.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_webhook_secret_here

# Port for the Express server. Railway/Render inject this automatically.
PORT=3000
